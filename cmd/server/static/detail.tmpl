{{define "title"}}{{.Image.Filename}} - Wallpapers{{end}}

{{define "header"}}
<p class="mb-4">
  <a href="/">&larr; Back</a>
  <span class="ml-4 text-sm">
    <a href="/resolutions">Resolutions</a> &middot;
    <a href="/colors">Colors</a> &middot;
    <a href="/tags">Tags</a>
  </span>
</p>
{{end}}

{{define "page-styles"}}
<style>
  .main-image {
    max-width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--border-default);
  }

  .main-image:hover {
    border-color: var(--border-hover);
  }

  dl, dd {
    margin-left: 0;
  }
</style>
{{end}}

{{define "content"}}
<div class="text-center mb-4">
  <img src="{{.Image.FullRezURL}}" alt="{{.Image.Filename}}" class="main-image" />
</div>
<p class="text-sm mt-2 mb-8 flex flex-wrap gap-x-4 gap-y-1 items-center">
  <a href="{{.Image.FullRezURL}}">Desktop Size (3840x2160)</a>
  <a href="{{.Image.RawURL}}">Original Image</a>
</p>

<article>
  <dl class="block mb-4">
    <dd class="text-sm font-bold ml-0 text-gray-500">Filename</dd>
    <dd class="text-xl font-bold ml-0 break-all">{{.Image.Filename}}</dd>
  </dl>

  <div class="flex flex-wrap gap-6">
    {{if and .Image.Width .Image.Height}}
    <dl>
      <dd class="text-sm font-bold ml-0 text-gray-500">Resolution</dd>
      <dd class="text-xl font-bold ml-0">{{.Image.Width}} &times; {{.Image.Height}}</dd>
    </dl>
    {{end}}

    {{if .Image.FileFormat}}
    <dl>
      <dd class="text-sm font-bold ml-0 text-gray-500">Format</dd>
      <dd class="text-xl font-bold ml-0 uppercase">{{.Image.FileFormat}}</dd>
    </dl>
    {{end}}

    {{if .Image.PixelDensity}}
    <dl>
      <dd class="text-sm font-bold ml-0 text-gray-500">Megapixels</dd>
      <dd class="text-xl font-bold ml-0">{{printf "%.1f" .Image.PixelDensity}} MP</dd>
    </dl>
    {{end}}

    <dl>
      <dd class="text-sm font-bold ml-0 text-gray-500">Added</dd>
      <dd class="text-xl font-bold ml-0">{{.Image.DateAdded.Format "Jan 2, 2006"}}</dd>
    </dl>

    {{if .Image.Colors}}
    <dl>
      <dd class="text-sm font-bold ml-0 text-gray-500">Colors</dd>
      <dd class="text-xl font-bold ml-0">
        {{range $i, $color := .Image.Colors}}{{if $i}} &middot; {{end}}<a href="/?q={{$color}}">{{$color}}</a>{{end}}
      </dd>
    </dl>
    {{end}}
  </div>

  <dl class="block mt-4">
    <dd class="text-sm font-bold ml-0 text-gray-500">Keywords</dd>
    <dd class="text-xl font-bold ml-0 break-words">
      {{if .Image.Words}}
      {{range $i, $word := .Image.Words}}{{if $i}} &middot; {{end}}<a href="/?q={{$word}}">{{$word}}</a>{{end}}
      {{else}}
      <span class="text-gray-400 italic">No keywords extracted yet</span>
      {{end}}
    </dd>
  </dl>
</article>
{{end}}
