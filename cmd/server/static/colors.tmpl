{{define "title"}}Colors - Wallpapers{{end}}

{{define "page-styles"}}
<style>
  .color-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1rem;
  }
  .color-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 44px;
    text-decoration: none;
  }
  .color-swatch {
    width: 36px;
    height: 36px;
    border-radius: 3px;
    border: 1px solid rgba(0,0,0,0.12);
    display: block;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .color-item:hover .color-swatch {
    transform: scale(1.08);
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }
  .color-hex {
    font-size: 0.65rem;
    color: #555;
    margin-top: 0.25rem;
    text-align: center;
    font-family: monospace;
  }
  .color-count {
    font-size: 0.6rem;
    color: #999;
    text-align: center;
  }
</style>
{{end}}

{{define "content"}}
<h2 class="f3 mb1">Colors</h2>
<p class="f6 gray mb3">{{len .Colors}} unique colors extracted from wallpapers. Click to browse similar colors.</p>

<div class="color-grid">
  {{range .Colors}}
  <a href="/?q={{.Hex}}" class="color-item" title="{{.Hex}} — {{.Count}} wallpaper{{if ne .Count 1}}s{{end}}">
    <span class="color-swatch" style="background-color: {{.Hex}};"></span>
    <span class="color-hex">{{.Hex}}</span>
    <span class="color-count">{{.Count}}</span>
  </a>
  {{end}}
</div>
{{end}}
