{{define "title"}}Colors - Wallpapers{{end}}

{{define "page-styles"}}
<style>
  .color-grid {
    display: grid;
    grid-template-columns: repeat(18, 1fr);
    gap: 3px;
    margin-top: 1rem;
  }
  .color-swatch {
    aspect-ratio: 1;
    border-radius: 2px;
    border: 1px solid rgba(0,0,0,0.1);
    display: block;
    transition: transform 0.1s;
    position: relative;
  }
  .color-swatch:hover {
    transform: scale(1.4);
    z-index: 1;
    box-shadow: 0 2px 6px rgba(0,0,0,0.3);
  }
  .color-swatch.no-match {
    opacity: 0.15;
  }
</style>
{{end}}

{{define "content"}}
<h2 class="f3 mb1">Colors</h2>
<p class="f6 gray mb3">Color grid: black left, white right. Bright cells have matching wallpapers; click to browse. Dimmed cells have no matches.</p>

<div class="color-grid">
  {{range .Colors}}
  <a href="/?q={{.Hex}}" class="color-swatch{{if eq .Count 0}} no-match{{end}}"
     style="background-color: {{.Hex}};"
     title="{{.Hex}} — {{.Count}} wallpaper{{if ne .Count 1}}s{{end}}"></a>
  {{end}}
</div>
{{end}}
