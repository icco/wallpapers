{{define "title"}}Resolutions - Wallpapers{{end}}

{{define "content"}}
<h2 class="text-2xl font-bold mb-2">Resolutions</h2>
<p class="text-sm text-gray-500 mb-4">{{len .Resolutions}} unique resolutions. Click to browse matching wallpapers.</p>

<div class="flex flex-wrap gap-2 mt-4">
  {{range .Resolutions}}
  <a href="/?q={{.Width}}x{{.Height}}" class="badge badge-outline gap-1 no-underline">
    {{.Width}}×{{.Height}}<span class="text-gray-400 text-xs ml-0.5">{{.Count}}</span>
  </a>
  {{end}}
</div>
{{end}}
