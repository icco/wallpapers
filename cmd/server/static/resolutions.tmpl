{{define "title"}}Resolutions - Wallpapers{{end}}

{{define "page-styles"}}
<style>
  .res-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .res-item {
    display: inline-block;
    padding: 0.4rem 0.75rem;
    border: 1px solid #CCC;
    border-radius: 4px;
    font-size: 0.9rem;
    white-space: nowrap;
    text-decoration: none;
  }
  .res-item:hover {
    border-color: #2BA6CB;
  }
  .count {
    color: #888;
    font-size: 0.8rem;
    margin-left: 0.25rem;
  }
</style>
{{end}}

{{define "content"}}
<h2 class="f3 mb1">Resolutions</h2>
<p class="f6 gray mb3">{{len .Resolutions}} unique resolutions. Click to browse matching wallpapers.</p>

<div class="res-list">
  {{range .Resolutions}}
  <a href="/?q={{.Width}}x{{.Height}}" class="res-item">
    {{.Width}}×{{.Height}}<span class="count">{{.Count}}</span>
  </a>
  {{end}}
</div>
{{end}}
