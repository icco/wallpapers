{{define "title"}}Wallpapers{{end}}

{{define "container-class"}}p-4 max-w-5xl mx-auto{{end}}

{{define "header"}}
<h1 class="m-0 p-0"><a href="/">Wallpapers</a></h1>
<h2 class="text-lg my-1">A Nat Welch Collection</h2>
<nav class="text-sm mb-3">
  <a href="/resolutions">Resolutions</a> &middot;
  <a href="/colors">Colors</a> &middot;
  <a href="/tags">Tags</a>
</nav>
{{end}}

{{define "page-styles"}}
<style>
  /* Desktop: 3 columns */
  @media (min-width: 900px) {
    .item { width: calc(33.333% - 3px); }
  }

  /* Tablet: 2 columns */
  @media (min-width: 600px) and (max-width: 899px) {
    .item { width: calc(50% - 3px); }
  }

  /* Mobile: 1 column */
  @media (max-width: 599px) {
    .item { width: calc(100% - 2px); }
  }

  .item img {
    width: 100%;
    height: auto;
    display: block;
  }

  .item {
    padding: 1px;
    border: 1px solid #CCC;
    margin: 1px;
    box-sizing: border-box;
  }

  .item:hover {
    border-color: #2BA6CB;
  }
</style>
{{end}}

{{define "content"}}
<div class="mb-4 px-1">
  <form action="/" method="get" class="flex flex-wrap gap-2 items-center my-4">
    <input type="text" name="q" class="input input-bordered w-full max-w-xs"
      placeholder="Search by word, color, or resolution..."
      value="{{.Query}}" />
    <button type="submit" class="btn btn-primary">Search</button>
    {{if .Query}}<a href="/" class="link text-sm ml-1">Clear</a>{{end}}
  </form>
  <p class="text-sm text-gray-500 mt-1">Try: mountain, sunset, #ff0000, 1920x1080, jpeg</p>
  <p class="text-sm text-gray-700 mb-1">
    {{if .Query}}
    {{len .Images}} result{{if ne (len .Images) 1}}s{{end}} for &#34;{{.Query}}&#34;
    {{else}}
    {{len .Images}} wallpapers
    {{end}}
  </p>
</div>

<div id="box" class="thumbnails">
  {{range .Images}}
  <div class="item">
    <a href="/image/{{.Filename}}" title="{{.Filename}}{{if and .Width .Height}} ({{.Width}}x{{.Height}}){{end}}">
      <img src="{{.ThumbnailURL}}" alt="{{.Filename}}{{if and .Width .Height}} ({{.Width}}x{{.Height}}){{end}}"
        width="800" height="450" loading="lazy" />
    </a>
  </div>
  {{end}}
</div>
{{end}}

{{define "scripts"}}
<script src="/js/imagesloaded.pkgd.min.js"></script>
<script src="/js/isotope.pkgd.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    var box = document.getElementById('box');

    var iso = new Isotope(box, {
      itemSelector: '.item',
      layoutMode: 'masonry'
    });

    imagesLoaded(box, function () {
      iso.layout();
    });
  });
</script>
{{end}}
